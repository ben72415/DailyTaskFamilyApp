<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">


        <TextView
            android:id="@+id/tvEditTitleHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task Details"
            android:textColor="#111111"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="15dp"/>

        <!-- 任務狀態複選框 / Workflow Status Status -->
        <CheckBox
            android:id="@+id/cbEditStatus"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Mark this workflow task as [COMPLETED]"
            android:textSize="15sp"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:layout_marginBottom="15dp"/>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task Notes / Update Descriptions"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/etEditTaskNotes"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Provide progression notes here..."
            android:gravity="top"
            android:inputType="textMultiLine"
            android:textSize="16sp"
            android:background="@android:drawable/editbox_background"
            android:padding="8dp"
            android:layout_marginBottom="15dp"/>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎙️ Supplemental Voice Memo"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="5dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnEditStartRecord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Record"
                android:backgroundTint="#E53935"
                android:layout_marginRight="4dp"/>

            <Button
                android:id="@+id/btnEditStopRecord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop"
                android:enabled="false"
                android:backgroundTint="#757575"
                android:layout_marginHorizontal="2dp"/>

            <Button
                android:id="@+id/btnEditPlayRecord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Play"
                android:backgroundTint="#4CAF50"
                android:layout_marginLeft="4dp"/>
        </LinearLayout>


        <TextView
            android:id="@+id/tvEditImageCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attachments (Long press image to delete): 0/10"
            android:textColor="#555555"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="15dp">

            <Button
                android:id="@+id/btnEditPickImage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🖼️ Add Photo"
                android:backgroundTint="#1976D2"
                android:layout_marginRight="4dp"/>

            <Button
                android:id="@+id/btnEditCaptureImage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📷 Snap"
                android:backgroundTint="#8E24AA"
                android:layout_marginLeft="4dp"/>
        </LinearLayout>


        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="25dp"
            android:background="#F9F9F9">
            <LinearLayout
                android:id="@+id/layoutEditImageContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="4dp"/>
        </HorizontalScrollView>

        <!-- 核心操作按鈕群組 / Core Operations Buttons -->
        <Button
            android:id="@+id/btnEditReschedule"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📅 Reschedule Date &amp; Time"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnEditSaveTask"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Consolidated Changes"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>