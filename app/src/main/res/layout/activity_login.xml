<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="30dp"
    android:background="#FFFFFF">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DailyTask"
        android:textColor="#2196F3"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="5dp"/>


    <TextView
        android:id="@+id/tvLoginSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Family Task Collaboration System"
        android:textColor="#777777"
        android:textSize="14sp"
        android:layout_marginBottom="30dp"
        android:gravity="center"/>


    <EditText
        android:id="@+id/etLoginName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Full Name"
        android:inputType="textPersonName"
        android:visibility="gone"
        android:layout_marginBottom="12dp"
        android:paddingHorizontal="10dp"
        android:background="@android:drawable/editbox_background"/>


    <EditText
        android:id="@+id/etLoginEmail"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Email Address"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="12dp"
        android:paddingHorizontal="10dp"
        android:background="@android:drawable/editbox_background"/>

    <!-- 密碼輸入框 / Password Box -->
    <EditText
        android:id="@+id/etLoginPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Password (min 6 characters)"
        android:inputType="textPassword"
        android:layout_marginBottom="12dp"
        android:paddingHorizontal="10dp"
        android:background="@android:drawable/editbox_background"/>

    <!-- 確認密碼輸入框 / Confirm Password Box -->
    <EditText
        android:id="@+id/etLoginConfirmPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Confirm Password"
        android:inputType="textPassword"
        android:visibility="gone"
        android:layout_marginBottom="20dp"
        android:paddingHorizontal="10dp"
        android:background="@android:drawable/editbox_background"/>


    <Button
        android:id="@+id/btnMainAction"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Secure Login"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2196F3"
        android:layout_marginBottom="15dp"/>


    <TextView
        android:id="@+id/tvSwitchMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't have an account? Tap here to Register"
        android:textColor="#1976D2"
        android:textSize="14sp"
        android:padding="10dp"
        android:gravity="center"/>

</LinearLayout>