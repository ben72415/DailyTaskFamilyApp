<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="30dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Family Workspace"
        android:textColor="#1976D2"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="To begin syncing workflow tasks, please create a new family group or join an existing one."
        android:textColor="#666666"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnCreateGroup"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Setup New Family Group (As Admin)"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="35dp"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="35dp">
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_centerInParent="true"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" OR JOIN VIA CODE "
            android:textColor="#999999"
            android:textSize="12sp"
            android:background="#FFFFFF"
            android:paddingHorizontal="10dp"
            android:layout_centerInParent="true"/>
    </RelativeLayout>

    <EditText
        android:id="@+id/etGroupCode"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Enter 6-Digit Invite Code"
        android:inputType="textCapCharacters"
        android:maxLength="6"
        android:gravity="center"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:background="@android:drawable/editbox_background"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnJoinGroup"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Join Existing Family"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"/>

</LinearLayout>