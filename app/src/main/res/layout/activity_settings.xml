<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginBottom="15dp">

        <ImageView
            android:id="@+id/ivUserIcon"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginBottom="15dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerCrop"
            android:background="@android:color/darker_gray"
            android:clipToOutline="true" />
        <TextView
            android:id="@+id/tvSettingsName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="姓名：載入中..."
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2C3E50" />

        <TextView
            android:id="@+id/tvSettingsEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email：載入中..."
            android:textSize="14sp"
            android:textColor="#7F8C8D"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvSettingsGroupCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔑 家庭邀請碼：------"
            android:textSize="14sp"
            android:textColor="#2980B9"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="15dp">

            <Button
                android:id="@+id/btnChangePassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="修改密碼"
                android:backgroundTint="#7F8C8D" />

            <Button
                android:id="@+id/btnRegenGroupCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="刷新新代碼"
                android:backgroundTint="#2980B9" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="家庭組員與權限管理"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        android:layout_marginBottom="10dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGroupMembers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:layout_marginBottom="15dp" />

    <Button
        android:id="@+id/btnLeaveGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="退出目前家庭群組"
        android:backgroundTint="#E67E22"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="登出"
        android:backgroundTint="#C0392B" />

</LinearLayout>