<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/ivUserIcon"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:src="@android:drawable/ic_menu_gallery"
                android:scaleType="centerCrop"
                android:contentDescription="User Avatar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(Tap avatar icon to upload new)"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginTop="5dp"/>
        </LinearLayout>


        <TextView
            android:id="@+id/tvSettingsName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Name: Fetching..."
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvSettingsEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email: Fetching..."
            android:textColor="#666666"
            android:textSize="14sp"
            android:layout_bottom="6dp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvSettingsGroupCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔑 Family Invite Code: Fetching..."
            android:textColor="#1565C0"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>


        <Button
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Update Security Password"
            android:backgroundTint="#607D8B"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnRegenGroupCode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🔄 Refresh Family Invite Code"
            android:backgroundTint="#2980B9"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnLeaveGroup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🏃‍♂️ Leave Current Family Group"
            android:backgroundTint="#E67E22"
            android:layout_marginBottom="20dp"/>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Family Hierarchy &amp; Active Members"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGroupMembers"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#F5F5F5"
            android:padding="5dp"
            android:layout_marginBottom="25dp"/>


        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Secure Logout from System"
            android:backgroundTint="#C62828"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>