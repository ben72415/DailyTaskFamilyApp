<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F9F9FA">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cloud Sync: New Family Task"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assign Member"
                android:textSize="16sp"
                android:textColor="#555555"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinnerMember"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@android:drawable/btn_dropdown"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Task Title"
                android:textSize="16sp"
                android:textColor="#555555"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etTaskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter family task title..."
                android:background="@android:drawable/editbox_background"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:inputType="text"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btnSelectStartTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="Set Start Time"
                    android:backgroundTint="#78909C" />

                <Button
                    android:id="@+id/btnSelectEndTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Set End Time"
                    android:backgroundTint="#78909C" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSelectedTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time Slot: 12:00 - 13:00"
                android:textSize="16sp"
                android:textColor="#2980B9"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notes / Descriptions"
                android:textSize="16sp"
                android:textColor="#555555"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etTaskNotes"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@android:drawable/editbox_background"
                android:padding="10dp"
                android:gravity="top|left"
                android:layout_marginBottom="20dp"
                android:inputType="textMultiLine"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice Memo"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btnStartRecord"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Record"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#E74C3C"
                    android:textColor="@android:color/white"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

                <Button
                    android:id="@+id/btnStopRecord"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:text="Stop"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#7F8C8D"
                    android:textColor="@android:color/white"
                    android:enabled="false"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

                <Button
                    android:id="@+id/btnPlayRecord"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Play"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#2ECC71"
                    android:textColor="@android:color/white"
                    android:enabled="false"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvImageCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Photo Attachments (Max 10): 0/10"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnAddTaskImage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="Import"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#2196F3"
                    android:textColor="@android:color/white"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />

                <Button
                    android:id="@+id/btnCaptureImage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Camera"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#9C27B0"
                    android:textColor="@android:color/white"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginBottom="24dp"
                android:background="#ECEFF1"
                android:padding="5dp">

                <LinearLayout
                    android:id="@+id/layoutImagePreviewContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />
            </HorizontalScrollView>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSaveTask"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Publish Task"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"/>

</LinearLayout>